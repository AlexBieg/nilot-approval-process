---
import ScrollPin from '../components/ScrollPin.astro';
---

<ScrollPin id="problem">
  <div class="max-w-4xl w-full px-8">
    <h2 class="text-3xl sm:text-5xl md:text-7xl font-display font-bold opacity-0" data-anim="headline">
      Why do we have <br /> this process?
    </h2>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
      <p id="body1-text" class="text-lg sm:text-xl text-text-muted leading-relaxed relative" data-anim="body1">
        Men are categorically, and say it with me now, trash. 
      </p>

      <div class="bg-card rounded-3xl p-4 sm:p-8 shadow-sm opacity-0" data-anim="card1">
        <p class="text-3xl sm:text-6xl font-display font-bold text-primary">4 / 4</p>
        <p class="text-text-muted mt-2 text-lg">Nilots Agree</p>
        <p class="text-sm text-text-muted mt-4 leading-relaxed break-words">
          Based on empirical studies from Pew Research Center
        </p>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-card-alt rounded-3xl p-4 sm:p-8 shadow-sm opacity-0" data-anim="card2">
        <p class="text-3xl sm:text-6xl font-display font-bold text-secondary">43%</p>
        <p class="text-text-muted mt-2 text-lg">Heterosexual Men</p>
        <p class="text-sm text-text-muted mt-4 leading-relaxed break-words">
          CAN'T IDENTIFY WHEN THEIR WIFE HAS AN ORGASM (<a href="https://pubmed.ncbi.nlm.nih.gov/29960888/">this is real somehow</a>)
        </p>
      </div>

      <p class="text-lg sm:text-xl text-text-muted opacity-0 leading-relaxed" data-anim="body2">
        This is your chance to prove you sit on top of the trash heap. Like a little trash king.
      </p>
    </div>
  </div>
</ScrollPin>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const body1 = document.getElementById('body1-text');
  if (body1) {
    const letters = body1.textContent.split('').map(ch =>
      `<span class="problem-letter" style="opacity:0">${ch}</span>`
    );
    body1.innerHTML = letters.join('');
  }

  let highlightSvg = null;

  const tl = gsap.timeline({ paused: true });

  const problemIO = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && tl.progress() === 0) tl.play();
  }, { threshold: 0.1 });
  problemIO.observe(document.getElementById('problem'));

  tl.to('[data-anim="headline"]', { opacity: 1, duration: 0.3 })
    .to('#body1-text .problem-letter', {
      opacity: 1,
      duration: 0.02,
      stagger: { each: 0.035, from: 'start' },
    })
    .call(drawTrashHighlight)
    .to({}, { duration: 0.2 })
    .to('[data-anim="card1"]', { opacity: 1, scale: 1, duration: 0.4 }, '-=0.1')
    .to('[data-anim="card2"]', { opacity: 1, scale: 1, duration: 0.4 })
    .to('[data-anim="body2"]', { opacity: 1, duration: 0.4 });

  function drawTrashHighlight() {
    if (body1.dataset.drawn === 'true') return;
    body1.dataset.drawn = 'true';

    const allLetters = Array.from(document.querySelectorAll('#body1-text .problem-letter'));
    const text = allLetters.map(s => s.textContent).join('');
    const idx = text.lastIndexOf('trash');
    if (idx === -1) return;

    const trashSpans = allLetters.slice(idx, idx + 5);
    const parentRect = body1.getBoundingClientRect();
    const first = trashSpans[0].getBoundingClientRect();
    const last = trashSpans[trashSpans.length - 1].getBoundingClientRect();

    const w = last.right - first.left;
    const x = first.left - parentRect.left;
    const y = first.bottom - parentRect.top - 4;

    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', `0 0 ${w} 14`);
    svg.setAttribute('width', w);
    svg.setAttribute('height', 14);
    svg.style.cssText = `position:absolute;left:${x}px;top:${y}px;pointer-events:none;overflow:visible;`;

    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    const d = `M 2 10 Q ${w * 0.15} 3 ${w * 0.35} 9 T ${w * 0.65} 7 T ${w - 2} 5`;
    path.setAttribute('d', d);
    path.setAttribute('stroke', 'var(--color-secondary)');
    path.setAttribute('stroke-width', window.innerWidth < 768 ? '4' : '6');
    path.setAttribute('fill', 'none');
    path.setAttribute('stroke-linecap', 'round');
    path.setAttribute('stroke-linejoin', 'round');

    svg.appendChild(path);
    body1.appendChild(svg);
    highlightSvg = svg;

    const len = path.getTotalLength();
    gsap.fromTo(path,
      { strokeDasharray: len, strokeDashoffset: len },
      { strokeDashoffset: 0, duration: 0.6, ease: 'power2.out' }
    );
  }

  function removeTrashHighlight() {
    if (highlightSvg) {
      highlightSvg.remove();
      highlightSvg = null;
      body1.dataset.drawn = '';
    }
  }
</script>
