---
const sections = [
  { id: 'hero', label: 'Intro' },
  { id: 'problem', label: 'Problem' },
  { id: 'process', label: 'Process' },
  { id: 'quiz', label: 'Quiz' },
  { id: 'outcome', label: 'Outcome' },
  // { id: 'footer', label: 'End' },
];
---

<nav class="dot-nav fixed right-6 top-1/2 -translate-y-1/2 z-50 hidden md:flex flex-col gap-4" aria-label="Section navigation">
  {sections.map(({ id, label }) => (
    <button
      data-dot={id}
      aria-label={`Jump to ${label}`}
      title={label}
      class="w-3 h-3 rounded-full border-2 border-text-muted/40 transition-all duration-300 hover:scale-150 hover:border-primary active:scale-125"
    >
    </button>
  ))}
</nav>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const dots = document.querySelectorAll('[data-dot]');

  function setActive(id) {
    dots.forEach(d => {
      if (d.dataset.dot === id) {
        d.classList.add('bg-primary', 'border-primary');
      } else {
        d.classList.remove('bg-primary', 'border-primary');
      }
    });
  }

  const sections = ['hero', 'problem', 'process', 'quiz', 'outcome', 'footer'];

  sections.forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;

    ScrollTrigger.create({
      trigger: el,
      start: 'top center',
      end: 'bottom center',
      onEnter: () => setActive(id),
      onEnterBack: () => setActive(id),
    });
  });

  function getActiveSection() {
    const center = window.innerHeight / 2 + window.scrollY;
    let active = sections[0];
    for (const id of sections) {
      const el = document.getElementById(id);
      if (!el || el.offsetParent === null) continue;
      const rect = el.getBoundingClientRect();
      if (rect.top + window.scrollY <= center) active = id;
    }
    return active;
  }

  ScrollTrigger.addEventListener('refresh', () => setActive(getActiveSection()));
  ScrollTrigger.refresh();

  const quizSection = document.getElementById('quiz');
  if (quizSection) {
    const observer = new MutationObserver(() => {
      if (quizSection.dataset.completed === 'true') {
        ScrollTrigger.refresh();
      }
    });
    observer.observe(quizSection, { attributes: true, attributeFilter: ['data-completed'] });
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const id = dot.dataset.dot;
      if (!id) return;
      const el = document.getElementById(id);
      if (!el) return;

      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      setActive(id);
    });
  });
</script>
